<?xml version="1.0"?>
<robot name="warehouse_robot">

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 1.0"/>
      <geometry>
        <box size="5 5 2"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.5 0.9 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 1.0"/>
      <geometry>
        <box size="5 5 2"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0"/>
  </joint>

</robot>
